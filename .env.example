# ─── App ───────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/innobyte?sslmode=require

# ─── Redis (Redis Cloud) ───────────────────────────────────────────────────────
REDIS_URL=redis://default:password@redis-xxxxx.c1.us-east-1-4.ec2.redns.redis-cloud.com:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_64_char_string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Cloudflare R2 Storage ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=innobyte-documents
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Internal Services ─────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
SCRAPING_SERVICE_URL=http://localhost:8002
INTERNAL_API_KEY=change_me_to_random_64_char_string_shared_with_ai_and_scraping

# ─── KYC (Sumsub) ─────────────────────────────────────────────────────────────
SUMSUB_APP_TOKEN=your_sumsub_app_token
SUMSUB_SECRET_KEY=your_sumsub_secret_key
