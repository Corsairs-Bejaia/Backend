generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users (tenants / dashboard users) ──────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  companyName  String   @map("company_name")
  planTier     String   @default("free") @map("plan_tier")
  createdAt    DateTime @default(now()) @map("created_at")

  apiKeys          ApiKey[]
  doctors          Doctor[]
  verifications    Verification[]
  tenantConfig     TenantConfig?
  webhookEndpoints WebhookEndpoint[]
  reviewedReports  VerificationReport[] @relation("ReviewedBy")
  reviewComments   ReviewComment[]

  @@map("users")
}

// ─── API Keys ────────────────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  name        String
  keyHash     String    @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  permissions String[]  @default(["verifications:read", "verifications:write"])
  rateLimit   Int       @default(100) @map("rate_limit")
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─── Doctors ─────────────────────────────────────────────────────────────────

model Doctor {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  fullNameFr       String   @map("full_name_fr")
  fullNameAr       String?  @map("full_name_ar")
  nationalIdNumber String   @map("national_id_number")
  status           String   @default("pending")
  createdAt        DateTime @default(now()) @map("created_at")

  tenant        User           @relation(fields: [tenantId], references: [id])
  verifications Verification[]

  @@unique([tenantId, nationalIdNumber])
  @@map("doctors")
}

// ─── Verifications ───────────────────────────────────────────────────────────

model Verification {
  id                 String    @id @default(cuid())
  doctorId           String    @map("doctor_id")
  tenantId           String    @map("tenant_id")
  workflowConfigJson Json?     @map("workflow_config_json")
  status             String    @default("pending")
  score              Float?
  decision           String?
  startedAt          DateTime  @default(now()) @map("started_at")
  completedAt        DateTime? @map("completed_at")
  sessionToken       String?   @unique @map("session_token")
  sessionExpiresAt   DateTime? @map("session_expires_at")
  redirectUrl        String?   @map("redirect_url")

  doctor    Doctor              @relation(fields: [doctorId], references: [id])
  tenant    User                @relation(fields: [tenantId], references: [id])
  steps     VerificationStep[]
  documents Document[]
  auditLogs AuditLog[]
  report    VerificationReport?

  @@map("verifications")
}

// ─── Verification Steps ──────────────────────────────────────────────────────

model VerificationStep {
  id             String    @id @default(cuid())
  verificationId String    @map("verification_id")
  stepType       String    @map("step_type")
  status         String    @default("pending")
  resultJson     Json?     @map("result_json")
  confidence     Float?
  errorMessage   String?   @map("error_message")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")

  verification Verification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@map("verification_steps")
}

// ─── Document Templates ──────────────────────────────────────────────────────

model DocumentTemplate {
  id                  String   @id @default(cuid())
  tenantId            String?  @map("tenant_id")
  name                String
  slug                String   @unique
  docType             String   @map("doc_type")
  description         String?
  sampleImageUrl      String?  @map("sample_image_url")
  isSystem            Boolean  @default(false) @map("is_system")
  isActive            Boolean  @default(true) @map("is_active")
  fieldsSchemaJson    Json?    @map("fields_schema_json")
  fieldPositionsJson  Json?    @map("field_positions_json")
  validationRulesJson Json?    @map("validation_rules_json")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  fields    DocumentTemplateField[]
  documents Document[]

  @@map("document_templates")
}

// ─── Document Template Fields ────────────────────────────────────────────────

model DocumentTemplateField {
  id               String  @id @default(cuid())
  templateId       String  @map("template_id")
  fieldName        String  @map("field_name")
  fieldLabelFr     String  @map("field_label_fr")
  fieldLabelAr     String? @map("field_label_ar")
  fieldType        String  @map("field_type")
  isRequired       Boolean @default(true) @map("is_required")
  positionHintJson Json?   @map("position_hint_json")
  validationRegex  String? @map("validation_regex")
  sortOrder        Int     @default(0) @map("sort_order")

  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("document_template_fields")
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id                String   @id @default(cuid())
  verificationId    String   @map("verification_id")
  docType           String   @map("doc_type")
  templateId        String?  @map("template_id")
  filePath          String   @map("file_path")
  ocrResultJson     Json?    @map("ocr_result_json")
  authenticityScore Float?   @map("authenticity_score")
  uploadedAt        DateTime @default(now()) @map("uploaded_at")

  verification Verification      @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  template     DocumentTemplate? @relation(fields: [templateId], references: [id])

  @@map("documents")
}

// ─── Audit Logs ──────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(cuid())
  verificationId String   @map("verification_id")
  action         String
  actor          String
  detailsJson    Json?    @map("details_json")
  timestamp      DateTime @default(now())

  verification Verification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ─── Webhook Endpoints ───────────────────────────────────────────────────────
// Tenant-facing webhook endpoints. svixEndpointId is internal only — never
// exposed to the tenant. Tenants interact using our own `id` field.

model WebhookEndpoint {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  url            String
  description    String?
  eventTypes     String[] @map("event_types")
  isActive       Boolean  @default(true) @map("is_active")
  svixEndpointId String   @map("svix_endpoint_id")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant User @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("webhook_endpoints")
}

// ─── Tenant Configs ──────────────────────────────────────────────────────────

model TenantConfig {
  id                     String @id @default(cuid())
  userId                 String @unique @map("user_id")
  requiredStepsJson      Json?  @map("required_steps_json")
  optionalStepsJson      Json?  @map("optional_steps_json")
  autoApproveThreshold   Float  @default(85) @map("auto_approve_threshold")
  manualReviewThreshold  Float  @default(60) @map("manual_review_threshold")
  allowedSpecialtiesJson Json?  @map("allowed_specialties_json")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

// ─── Verification Reports ────────────────────────────────────────────────────
// Created automatically when a verification ends in manual_review or rejected.
// Tenant reviewer reads the AI-generated content and submits a final decision.

model VerificationReport {
  id             String    @id @default(cuid())
  verificationId String    @unique @map("verification_id")
  // AI-generated content (markdown or JSON string) summarising the result.
  // Populated by the processor stub now; replaced by AiClientService later.
  contentFormat  String    @default("markdown") @map("content_format")
  contentRaw     String    @map("content_raw")
  // Review state: pending_review → reviewed
  status         String    @default("pending_review")
  // Set when the tenant reviewer submits a decision
  decision       String? // "approved" | "rejected" | "resubmit"
  decisionNote   String?   @map("decision_note")
  reviewedBy     String?   @map("reviewed_by")
  reviewedAt     DateTime? @map("reviewed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  verification Verification    @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  reviewer     User?           @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  comments     ReviewComment[]

  @@map("verification_reports")
}

// ─── Review Comments ─────────────────────────────────────────────────────────
// Inline comments added by the tenant reviewer while inspecting a report.

model ReviewComment {
  id        String   @id @default(cuid())
  reportId  String   @map("report_id")
  authorId  String   @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  report VerificationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  author User               @relation(fields: [authorId], references: [id])

  @@map("review_comments")
}
